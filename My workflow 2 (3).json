    {
      "parameters": {
        "jsCode": "// n8n Function node: parse JSON-looking string and produce clean fields for Sheets\nconst out = [];\n\nfor (const item of items) {\n  // the AI node put the JSON inside item.json.output (as a string)\n  const raw = item.json.output || item.json;\n\n  // clean code fences and accidental leading text\n  let txt = typeof raw === 'string' ? raw.replace(/```json|```/g, '').trim() : raw;\n\n  // sometimes your JSON has a stray \"json\\n\" prefix — strip that\n  txt = (typeof txt === 'string') ? txt.replace(/^json\\s*/, '') : txt;\n\n  let invoice;\n  if (typeof txt === 'string') {\n    try {\n      const firstBrace = txt.indexOf('{');\n      invoice = JSON.parse(firstBrace >= 0 ? txt.slice(firstBrace) : txt);\n    } catch (e) {\n      // fallback: empty safe object so workflow doesn't explode\n      invoice = {};\n    }\n  } else {\n    invoice = txt;\n  }\n\n  // normalize date to YYYY-MM-DD if possible\n  let normDate = invoice.date || '';\n  try {\n    const d = new Date(invoice.date);\n    if (!isNaN(d)) {\n      const yyyy = d.getFullYear();\n      const mm = String(d.getMonth() + 1).padStart(2, '0');\n      const dd = String(d.getDate()).padStart(2, '0');\n      normDate = `${yyyy}-${mm}-${dd}`;\n    }\n  } catch (e) {}\n\n  // flatten items array\n  const itemsArr = Array.isArray(invoice.items) ? invoice.items : [];\n  const items_flat = itemsArr.map(it => `${(it.item_name||'').replace(/\\r?\\n|\\|/g,' ')} (${it.item_amount ?? ''})`).join(' ; ');\n\n  out.push({\n    json: {\n      invoice_number: invoice.invoice_number || '',\n      date: normDate,\n      vendor_name: invoice.vendor_name || '',\n      total: invoice.total ?? '',\n      tax: invoice.tax ?? '',\n      items_flat,\n      raw_json: JSON.stringify(invoice)\n    }\n  });\n}\n\nreturn out;\n"
      },
