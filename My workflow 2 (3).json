    {
      "parameters": {
        "jsCode": "const raw = $json[\"ParsedResults\"][0][\"ParsedText\"];\n\nconst cleaned = raw\n  .replace(/\\r|\\n/g, \" \")       // flatten newlines\n  .replace(/\\s+/g, \" \")         // collapse spaces\n  .replace(/[^\\x00-\\x7F]/g, \"\") // strip weird characters\n  .replace(/\\s([.,:;!?])/g, \"$1\") // tidy punctuation spacing\n  .trim();\n\nreturn { json: { cleanedText: cleaned } };\n"
      },
